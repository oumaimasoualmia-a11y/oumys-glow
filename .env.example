# ============================================
# OUMY'S GLOW — Variables d'environnement
# ============================================
# Copier ce fichier en .env et remplir les valeurs

# --------------------------------------------
# BASE DE DONNÉES (Neon.tech — gratuit)
# --------------------------------------------
# 1. Créer un compte sur https://neon.tech
# 2. Créer un projet "oumy-glow"
# 3. Copier la connection string ci-dessous
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# --------------------------------------------
# NEXTAUTH — Authentification
# --------------------------------------------
# En production : URL de votre site Vercel (ex: https://oumy-glow.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# Générer une clé secrète (32 caractères min) :
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="REMPLACER_PAR_UNE_CLE_ALEATOIRE_DE_32_CHARS"

# --------------------------------------------
# WHATSAPP
# --------------------------------------------
# Format : +213 suivi du numéro (sans le 0 initial)
# Ex: +213551234567
NEXT_PUBLIC_WHATSAPP_NUMBER="+213XXXXXXXXX"

# --------------------------------------------
# URL DE L'APPLICATION
# --------------------------------------------
# En local : http://localhost:3000
# En production : https://votre-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Oumy's Glow"

# --------------------------------------------
# CLOUDINARY (optionnel — pour upload d'images)
# --------------------------------------------
# Créer un compte gratuit sur https://cloudinary.com
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --------------------------------------------
# NEON — Direct URL (pour prisma db push/migrate)
# --------------------------------------------
# Sur Neon, vous avez 2 URLs :
# - DATABASE_URL : pooled connection (pour l'app en production)
# - DIRECT_URL   : direct connection (pour les migrations)
# Les deux sont disponibles dans le dashboard Neon
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"
